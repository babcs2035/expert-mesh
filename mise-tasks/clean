#!/usr/bin/env bash
# Clean up all nodes.
# Default: docker compose down (stops and removes containers only; ollama model
# data in named volumes is preserved, so no model re-download on next start).
# With --full: docker compose down -v --rmi all (also removes named volumes
# and images), plus deletes the entire remote directory to restore nodes to
# a completely clean state.
set -euo pipefail
cd "$(dirname "$0")/.."

REMOTE_DIR=$(uv run python tools/remote_dir.py)
FULL_CLEAN=false

for arg in "$@"; do
  case "$arg" in
    --full) FULL_CLEAN=true ;;
    *)
      echo "[clean] unknown option: $arg" >&2
      echo "usage: mise run clean [-- --full]" >&2
      exit 1
      ;;
  esac
done

for host in $(uv run python tools/list_peers.py); do
  echo "=== $host ==="
  if [ "$FULL_CLEAN" = true ]; then
    echo "[clean] $host: docker compose down -v --rmi all (removes model data and images)"
    ssh "$host" "[ -d $REMOTE_DIR ] && (cd $REMOTE_DIR && docker compose down -v --rmi all) || echo '  (not deployed, skip)'"
    echo "[clean] $host: removing $REMOTE_DIR"
    ssh "$host" "rm -rf $REMOTE_DIR"
  else
    echo "[clean] $host: docker compose down (ollama model data preserved)"
    ssh "$host" "[ -d $REMOTE_DIR ] && (cd $REMOTE_DIR && docker compose down) || echo '  (not deployed, skip)'"
  fi
done

echo "[clean] done"
