#!/usr/bin/env bash
# Start all nodes: run docker compose up -d for ollama and expert-mesh containers.
#
# expert-mesh always uses --force-recreate. docker compose does not detect
# changes to the content of bind-mounted config.yaml, so without
# --force-recreate the container continues running with the old config
# even after config.yaml is updated.
# ollama starts on-demand via depends_on, and model data (named volume)
# is preserved even with --force-recreate.
set -euo pipefail
cd "$(dirname "$0")/.."

REMOTE_DIR=$(uv run python tools/remote_dir.py)

for host in $(uv run python tools/list_peers.py); do
  echo "[start] $host: docker compose up -d --force-recreate expert-mesh"
  ssh "$host" "cd $REMOTE_DIR && docker compose up -d --force-recreate expert-mesh"
done

# Model warmup (loading into ollama) takes tens of seconds to several minutes.
# Retry the healthcheck until all nodes pass.
# The operator terminal cannot reach the node LAN (192.168.15.0/24) directly,
# so the healthcheck runs from the first node's container over the same LAN.
echo "[start] waiting for warmup to complete (may take a few minutes)"
first_host=$(uv run python tools/list_peers.py | head -1)

MAX_RETRIES=30
RETRY_INTERVAL_S=10
for i in $(seq 1 "$MAX_RETRIES"); do
  if ssh "$first_host" "cd $REMOTE_DIR && docker compose exec -T expert-mesh .venv/bin/python tools/healthcheck.py"; then
    echo "[start] all nodes healthy"
    exit 0
  fi
  echo "[start] not ready yet (attempt $i/$MAX_RETRIES), retrying in ${RETRY_INTERVAL_S}s..."
  sleep "$RETRY_INTERVAL_S"
done

echo "[start] ERROR: nodes did not become healthy within timeout" >&2
exit 1
