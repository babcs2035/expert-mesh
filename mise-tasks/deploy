#!/usr/bin/env bash
# Deploy to all nodes: establish SSH reverse tunnels, distribute compose/config,
# pull images, and pull LLM models.
#
# If establishing a reverse tunnel to the registry fails (e.g., port forwarding
# is not allowed through ProxyJump), this script exits with an error. In that
# case, consider switching to manual image transfer:
# `docker save localhost:5001/expert-mesh:latest | ssh <host> docker load`
# We intentionally do not auto-fallback here so that connectivity issues are
# surfaced rather than silently swallowed.
set -euo pipefail
cd "$(dirname "$0")/.."

REMOTE_DIR=$(uv run python tools/remote_dir.py)
# Port 5000 is persistently used by another project (WAFL-PEFT) in this lab,
# so we use 5001 instead.
REGISTRY_PORT=5001

ensure_tunnel() {
  local host="$1"
  if ssh "$host" "curl -fsS -o /dev/null http://localhost:${REGISTRY_PORT}/v2/" 2>/dev/null; then
    echo "[deploy] $host: registry tunnel already up"
  else
    echo "[deploy] $host: opening reverse tunnel to local registry"
    ssh -fNT -R "${REGISTRY_PORT}:localhost:${REGISTRY_PORT}" "$host"
  fi
}

for host in $(uv run python tools/list_peers.py); do
  echo "=== $host ==="
  ensure_tunnel "$host"

  ssh "$host" "mkdir -p $REMOTE_DIR"
  # Use --inplace to overwrite files directly. The default rsync behavior
  # (write to a temp file then rename) changes the inode, which can cause
  # docker compose bind mounts to still serve the old content.
  rsync -az --inplace docker-compose.yml config.yaml "$host:$REMOTE_DIR/"
  ssh "$host" "echo NODE_ID=$host > $REMOTE_DIR/.env"

  echo "[deploy] $host: docker compose pull"
  ssh "$host" "cd $REMOTE_DIR && docker compose pull"

  echo "[deploy] $host: starting ollama container for model pull"
  ssh "$host" "cd $REMOTE_DIR && docker compose up -d ollama"

  for model in $(uv run python tools/node_models.py "$host"); do
    echo "[deploy] $host: ollama pull $model"
    ssh "$host" "cd $REMOTE_DIR && docker compose exec -T ollama ollama pull $model"
  done
done

echo "[deploy] done"
