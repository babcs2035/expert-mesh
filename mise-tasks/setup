#!/usr/bin/env bash
# Set up the local (operator terminal) environment: uv sync, Docker registry,
# build and push the expert-mesh image.
# The registry is published on 127.0.0.1 only, reachable via SSH reverse
# tunnels from remote hosts.
set -euo pipefail
cd "$(dirname "$0")/.."

echo "[setup] uv sync"
uv sync

# Port 5000 is persistently used by another project (WAFL-PEFT) in this lab,
# so we use 5001 instead.
REGISTRY_NAME="expert-mesh-registry"
REGISTRY_PORT=5001

if docker ps --format '{{.Names}}' | grep -qx "$REGISTRY_NAME"; then
  echo "[setup] registry container already running"
elif docker ps -a --format '{{.Names}}' | grep -qx "$REGISTRY_NAME"; then
  echo "[setup] starting existing registry container"
  docker start "$REGISTRY_NAME"
else
  echo "[setup] creating registry container (published on 127.0.0.1 only)"
  docker run -d --name "$REGISTRY_NAME" \
    -p "127.0.0.1:${REGISTRY_PORT}:5000" \
    --restart=always \
    registry:2
fi

echo "[setup] building expert-mesh image"
docker build -t "localhost:${REGISTRY_PORT}/expert-mesh:latest" .

echo "[setup] pushing expert-mesh image to local registry"
docker push "localhost:${REGISTRY_PORT}/expert-mesh:latest"

echo "[setup] done"
