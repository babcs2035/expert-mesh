#!/usr/bin/env bash
# Collect logs from all nodes. Phase 0 only does basic collection and line counts;
# metric calculations (Chapter 4 evaluation metrics) will be added in Phase 2
# as benchmark/metrics.py.
set -euo pipefail
cd "$(dirname "$0")/.."

REMOTE_DIR=$(uv run python tools/remote_dir.py)
LOG_DIR="logs"

mkdir -p "$LOG_DIR"

for host in $(uv run python tools/list_peers.py); do
  echo "=== $host ==="
  mkdir -p "$LOG_DIR/$host"
  ssh "$host" "cd $REMOTE_DIR && docker compose logs --no-color expert-mesh" \
    > "$LOG_DIR/$host/expert-mesh.log" 2>&1 || true
  line_count=$(wc -l < "$LOG_DIR/$host/expert-mesh.log")
  echo "  -> $LOG_DIR/$host/expert-mesh.log (${line_count} lines)"
done

echo "[analyze] done. Detailed metrics will be computed in Phase 2's benchmark/metrics.py"
